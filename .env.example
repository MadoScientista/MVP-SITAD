# JWT Secret - Clave para firmar tokens JWT (mínimo 32 caracteres)
# Se genera automáticamente al ejecutar scripts/cargar_env.ps1
JWT_SECRET=changeme

# Contraseña del usuario 'sitad' para las bases de datos MySQL
DB_PASSWORD=changeme

# Contraseña root de MySQL (usada por Docker Compose, no necesaria en local)
MYSQL_ROOT_PASSWORD=changeme

# Passwords de usuarios semilla (solo perfil dev)
ADMIN_PASSWORD=changeme
INSPECTOR_PASSWORD=changeme
