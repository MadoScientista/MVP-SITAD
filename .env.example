# JWT Secret - MUST be at least 256 bits for HMAC-SHA
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(64)).decode())"
JWT_SECRET=changeme

# Database credentials (shared across all MySQL instances)
DB_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme

# Dev seed user passwords (only used with -Dspring.profiles.active=dev)
ADMIN_PASSWORD=changeme
INSPECTOR_PASSWORD=changeme
